# Development env (Vite loads this for `npm run dev`)
# Keep base URL empty so all requests use the Vite proxy from vite.config.js.
VITE_API_BASE_URL=

# Used by OAuth redirect URL builder in `src/features/auth/api/authApi.js`.
# Point to your local Apache-served Laravel app.
VITE_BACKEND_ORIGIN=http://localhost:8080/ultra-hustle/bcakend_api/public
